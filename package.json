{
  "name": "sclshi",
  "version": "1.0.0",
  "description": "Sclshi — school-themed prediction markets",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "npx nodemon server.js",
    "desktop": "SCLSHI_DESKTOP_START_URL=https://sclshi.onrender.com electron ./electron/main.js",
    "desktop:local": "SCLSHI_DESKTOP_START_URL=http://localhost:3000 electron ./electron/main.js",
    "desktop:web": "SCLSHI_DESKTOP_START_URL=https://sclshi.onrender.com electron ./electron/main.js",
    "desktop:dir": "electron-builder --mac dir",
    "desktop:dist": "electron-builder --mac dmg"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.2",
    "resend": "^6.9.4",
    "stripe": "^21.0.1"
  },
  "devDependencies": {
    "electron": "^37.0.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.sclshi.desktop",
    "productName": "Sclshi",
    "directories": {
      "output": "dist/desktop"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "mac": {
      "category": "public.app-category.social-networking",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
